# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Multi-org / subdomain routing ─────────────────────────────
# Root domain for subdomain extraction (e.g. localhost:3000 for dev, yourdomain.com for prod)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Optional: single-org fallback (no subdomains required)
# NEXT_PUBLIC_ORGANIZATION_SLUG=your-org-slug

# ── SEO / canonical URLs ───────────────────────────────────────
# Primary canonical origin — used for sitemap, robots.txt, OG, and canonical tags
# Set to https://www.yourdomain.com in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App admin subdomain URL (used for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_WEEKLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Public pricing displayed in the UI
NEXT_PUBLIC_PRICE_PRO_WEEKLY=42.00
NEXT_PUBLIC_PRICE_PRO_MONTHLY=126.99
NEXT_PUBLIC_PRICE_PRO_YEARLY=999.00
